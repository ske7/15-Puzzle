  "private": true,
  "author": "Konstantyn Shatkovskyi",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix && stylelint **/*.vue"
  },
  "dependencies": {
